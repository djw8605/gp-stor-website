---
import Layout from '~/layouts/PageLayout.astro';
import Hero2 from '~/components/widgets/Hero2.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Stats from '~/components/widgets/Stats.astro';
import Button from '~/components/ui/Button.astro';
import usdTraining from '~/assets/images/training/university-of-south-dakota-training.jpeg';
import dakotaTraining from '~/assets/images/training/dakota-state-training.jpg';

const metadata = {
  title: 'GP-STOR Fellowships',
  description: 'Travel fellowships for students and researchers attending the GPN Annual Meeting in June 2026.',
};
---

<Layout metadata={metadata}>
  <div class="pt-12">
    <Hero2
      tagline="2026 Cohort — Applications Open"
      actions={[
        { text: 'Apply for the Fellowship', href: 'https://forms.gle/yTbLi5CuPxEd7imy5', variant: 'primary' },
        { text: 'View Meeting Details', href: '#gpn-annual-meeting', variant: 'secondary' },
      ]}
      image={{
        src: usdTraining,
        alt: 'Researchers participating in a GP-STOR training session',
        class: 'h-64 md:h-80 lg:h-[26rem] object-cover object-[center_30%]',
        caption: 'Training session at the University of South Dakota.',
      }}
    >
      <Fragment slot="title">GP-STOR Fellowships</Fragment>
      <Fragment slot="subtitle">
        Supporting students and faculty to attend the GPN Annual Meeting, June 22–24, 2026 in Rogers, Arkansas.
        Fellows participate in training sessions and connect with research computing professionals from across the region.
      </Fragment>
    </Hero2>
  </div>

  <!-- Key numbers at a glance -->
  <Stats
    title="What Fellows Receive"
    subtitle="Accepted fellows receive direct financial support and complimentary conference access."
    stats={[
      {
        amount: '$1,125',
        title: 'One-Time Travel Payment',
        icon: 'tabler:cash',
      },
      {
        amount: 'Free',
        title: 'Conference Registration',
        icon: 'tabler:ticket',
      },
      {
        amount: 'June 22–24',
        title: '2026 Annual Meeting',
        icon: 'tabler:calendar-event',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#D7F0E1] dark:bg-slate-800"></div>
    </Fragment>
  </Stats>

  <Features2
    title="Fellowship Benefits in Detail"
    subtitle="The fellowship is designed to remove cost barriers so researchers can focus on learning and networking."
    columns={2}
    items={[
      {
        title: '$1,125 Travel Payment',
        description:
          'Accepted fellows receive a single, one-time payment of $1,125 to cover hotel and mileage costs for travel to and from the conference. No itemized receipts required — just attend.',
        icon: 'tabler:cash',
      },
      {
        title: 'Free Conference Registration',
        description:
          'All fellows are already members of the Great Plains Network, so GPN Annual Meeting registration is included at no cost. You do not need to pay a registration fee.',
        icon: 'tabler:ticket',
      },
      {
        title: 'Training & Workshops',
        description:
          'Fellows participate in hands-on training sessions covering research cyberinfrastructure, HPC, AI/ML workflows, and the National Research Platform.',
        icon: 'tabler:school',
      },
      {
        title: 'Regional Networking',
        description:
          'Connect with research computing professionals, IT leaders, and peer institutions across the Great Plains region during two full days of programming.',
        icon: 'tabler:network',
      },
    ]}
  />

  <Content
    id="gpn-annual-meeting"
    title="About the GPN Annual Meeting"
    subtitle="A regional conference focused on practical training, collaboration, and research cyberinfrastructure."
    items={[
      {
        title: 'Joint 2026 conference',
        description:
          'The 2026 GPN Annual Meeting is held jointly with ARE-ON in Rogers, Arkansas on June 22–24, 2026.',
      },
      {
        title: 'Program format',
        description:
          'The program opens with a reception on June 22, followed by two full days of keynotes, breakout sessions, and panel discussions.',
      },
      {
        title: 'Who attends',
        description:
          'Research cyberinfrastructure professionals, higher education IT leaders, and research and education networking specialists from across the region.',
      },
      {
        title: 'Why fellows benefit',
        description:
          'Fellows learn directly from peer institutions, compare applied research computing workflows, and build collaborations they can bring back to their campuses.',
      },
    ]}
    image={{
      src: dakotaTraining,
      alt: 'Participants collaborating during a research computing session',
      caption: 'Training session at Dakota State University.',
    }}
  >
    <Fragment slot="content">
      <p class="mb-6">
        The conference features a multi-day program with technical sessions, sponsor showcases, and
        networking opportunities designed for the regional research computing community.
      </p>
      <div>
        <Button
          variant="primary"
          text="View GPN Annual Meeting Registration"
          href="https://www.eventbrite.com/e/gpn-are-on-joint-conference-2026-registration-1982010385417?aff=oddtdtcreator"
          target="_blank"
        />
      </div>
    </Fragment>
  </Content>

  <Content
    title="About the National Research Platform (NRP)"
    subtitle="Preparing researchers to use advanced national cyberinfrastructure resources."
    isReversed={true}
    items={[
      {
        title: 'Built on Kubernetes',
        description:
          'The National Research Platform (NRP) is a stretched, multi-tenant scientific Kubernetes cluster for allocatable and composable cyberinfrastructure.',
      },
      {
        title: 'Extensive GPU resources',
        description:
          'NRP provides large-scale GPU capacity designed to support compute-intensive projects across the United States.',
      },
      {
        title: 'Designed for AI and machine learning',
        description:
          'Its architecture is optimized for AI and machine learning workloads, including distributed training and data-intensive pipelines.',
      },
      {
        title: 'Fellowship outcomes',
        description:
          'The fellowship prepares researchers to use the NRP and other research computing systems effectively in their own research programs.',
      },
    ]}
    image={{
      src: usdTraining,
      alt: 'Researcher presenting to fellowship attendees',
      caption: 'Training session at the University of South Dakota.',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#D7F0E1] dark:bg-slate-800"></div>
    </Fragment>
  </Content>

  <CallToAction
    title="Ready to Join the Fellowship?"
    subtitle="Applications are open for the 2026 GP-STOR fellowship cohort. Accepted fellows receive a $1,125 travel payment and free conference registration. Apply now to attend the GPN Annual Meeting in Rogers, Arkansas."
    actions={[
      {
        text: 'Apply for the Fellowship',
        href: 'https://forms.gle/yTbLi5CuPxEd7imy5',
        variant: 'primary',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
